{
  "name": "std",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pedro's personal standard — shared Bun+TypeScript vocabulary for reports, notes, and CLIs.",
  "//publish": "name stays 'std' until the publish story flips it to '@pedroibl/std' (consumers alias: bun add std@npm:@pedroibl/std). private:true is the publish safety latch — do NOT flip until the name-flip + std/* self-reference decoupling lands (proof/ has 116 `std/*` self-imports resolved via package self-referencing).",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./report": "./src/report/index.ts",
    "./glab": "./src/glab/index.ts",
    "./cli": "./src/cli/index.ts",
    "./cn": "./src/cn/index.ts",
    "./dashkit": "./src/dashkit/index.ts",
    "./proc": "./src/proc/index.ts",
    "./git": "./src/git/index.ts",
    "./http": "./src/http/index.ts",
    "./fsx": "./src/fsx/index.ts",
    "./stdio": "./src/stdio/index.ts"
  },
  "bin": {
    "std": "./src/cli/main.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "typecheck:proof": "tsc -p proof/tsconfig.json",
    "typecheck:cn": "tsc -p src/cn/tsconfig.json && tsc -p src/cn/tsconfig.test.json",
    "typecheck:dashkit": "tsc -p src/dashkit/tsconfig.json && tsc -p src/dashkit/tsconfig.test.json",
    "check:core-purity": "bun run scripts/check-core-purity.ts",
    "check:dep-root": "bun run scripts/check-dep-root.ts",
    "check:single-source": "bun run scripts/check-single-source.ts",
    "check:no-consumer-ids": "bun run scripts/check-no-consumer-ids.ts",
    "review:cr": "bash scripts/cr-review.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0",
    "yaml": "^2.9.0"
  }
}
